<?xml version="1.0" encoding="utf-8"?>
<!--
  Full-bleed splash layout.

  The painted splash.png from drawable-port-* is set as the root background
  with centerCrop scale so it always fills the screen regardless of aspect.
  The Android system picks the right density bucket automatically.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_background">

    <ImageView
        android:id="@+id/splash_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/splash"
        android:contentDescription="@null" />

</FrameLayout>
